generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  status      ProjectStatus @default(editing)
  variantId   String
  size        String
  pageCount   Int
  pagesJson   Json?
  priceCents  Int
  currency    String   @default("usd")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  orders      Order[]
  assets      Asset[]

  @@map("projects")
}

model Asset {
  id          String   @id @default(cuid())
  projectId   String
  url         String
  storageKey  String
  width       Int
  height      Int
  exif        Json?
  createdAt   DateTime @default(now()) @map("created_at")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("assets")
}

enum ProjectStatus {
  editing
  ready
  ordered
  paid
}

model Order {
  id              String   @id @default(cuid())
  projectId       String
  stripeSessionId String   @unique
  paymentStatus   String
  amountTotal     Int
  currency        String
  createdAt       DateTime @default(now()) @map("created_at")
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("orders")
}

